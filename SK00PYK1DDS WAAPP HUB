-- TAB SWITCH LOGIC
local tabs = {
	{Btn = teleportTab, Holder = teleportHolder},
	{Btn = switchTab, Holder = switchHolder},
	{Btn = musicTab, Holder = musicHolder},
	{Btn = localPlayerTab, Holder = localPlayerHolder}
}

local function switchMenu(activeTab)
	for _, tabData in ipairs(tabs) do
		if tabData.Btn == activeTab then
			tabData.Holder.Visible = true
			tabData.Btn.BackgroundColor3 = accentDark
		else
			tabData.Holder.Visible = false
			tabData.Btn.BackgroundColor3 = buttonColor
		end
	end
end

