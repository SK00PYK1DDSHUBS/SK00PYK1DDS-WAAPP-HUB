-- Helper to make consistent Tab Buttons
local function createTab(name, index)
	local btn = Instance.new("TextButton")
	btn.Parent = categoryBar
	btn.Size = UDim2.new(0, 145, 0.8, 0) 
	btn.Position = UDim2.new(0, 10 + ((index-1) * 153), 0.1, 0)
	btn.BackgroundColor3 = buttonColor
	btn.Text = name
	btn.Font = Enum.Font.GothamBold
	btn.TextScaled = true 
	btn.TextColor3 = Color3.new(1,1,1)
	Instance.new("UICorner", btn).CornerRadius = UDim.new(0,8)
	
	local constraint = Instance.new("UITextSizeConstraint", btn)
	constraint.MaxTextSize = 18
	constraint.MinTextSize = 12
	
	return btn
end

